@model IEnumerable<Users.Models.UsersModel>

<div class="container mt-5">
    <h2>@(ViewData["title"] ?? "Users List")</h2>
    <a asp-action="Add" class="btn btn-success mb-3">Add New User</a>
    <table class="table table-striped mt-4">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var user in Model)
            {
                <tr>
                    <td>@user.UserId</td>
                    <td>@user.Name</td>
                    <td>@user.Email</td>
                    <td>@user.Role</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@user.UserId" class="btn btn-sm btn-primary me-2">Edit</a>
                        <form asp-action="Delete" asp-route-id="@user.UserId" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this user?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
