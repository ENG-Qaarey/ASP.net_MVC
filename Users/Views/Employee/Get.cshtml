@model IEnumerable<Users.Models.Employee>

<div class="container mt-5 app-section">
    <h2 class="app-title">Employees List</h2>

    <a asp-action="Add" class="btn btn-success mb-3">Add New Employee</a>

    <table class="table table-striped app-table">
        <thead class="app-table-head">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Job Title</th>
                <th>Created By</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var emp in Model)
            {
                <tr>
                    <td>@emp.Id</td>
                    <td>@emp.Name</td>
                    <td>@emp.Email</td>
                    <td>@emp.JobTitle</td>
                    <td>@emp.CreatedByUserID</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@emp.Id" class="btn btn-sm btn-primary me-2">Edit</a>
                        <form asp-action="Delete" asp-route-id="@emp.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this employee?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>