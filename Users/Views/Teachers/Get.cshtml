@model IEnumerable<Users.Models.TeachersModel>

<div class="container mt-5">
    <h2>@(ViewData["title"] ?? "Teachers List")</h2>
    <a asp-action="Add" class="btn btn-success mb-3">Add New Teacher</a>
    <table class="table table-striped mt-4">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Subject</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var teacher in Model)
            {
                <tr>
                    <td>@teacher.Id</td>
                    <td>@teacher.Name</td>
                    <td>@teacher.Email</td>
                    <td>@teacher.Subject</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@teacher.Id" class="btn btn-sm btn-primary me-2">Edit</a>
                        <form asp-action="Delete" asp-route-id="@teacher.Id" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Delete this teacher?');">Delete</button>
                        </form>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
