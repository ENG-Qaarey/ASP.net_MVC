@model IEnumerable<Users.Models.StudentsModel>

<div class="container mt-5">
    <h2>@(ViewData["title"] ?? "Students List")</h2>
    <table class="table table-striped mt-4">
        <thead class="table-dark">
            <tr>
                <th>Id</th>
                <th>Name</th>
                <th>Email</th>
                <th>Grade</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var student in Model)
            {
                <tr>
                    <td>@student.Id</td>
                    <td>@student.Name</td>
                    <td>@student.Email</td>
                    <td>@student.Grade</td>
                </tr>
            }
        </tbody>
    </table>
</div>
